{
  "name": "interview-prep",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "migrate:content": "node --env-file=.env scripts/migrate-content-to-mongo.mjs",
    "migrate:content:dry": "node --env-file=.env scripts/migrate-content-to-mongo.mjs --dry-run",
    "migrate:admin-user": "node --env-file=.env scripts/migrate-single-user-to-admin.mjs",
    "migrate:admin-user:dry": "node --env-file=.env scripts/migrate-single-user-to-admin.mjs --dry-run",
    "fix:question-slugs": "node --env-file=.env scripts/fix-question-slugs.mjs",
    "fix:question-slugs:dry": "node --env-file=.env scripts/fix-question-slugs.mjs --dry-run",
    "extension:dev": "pnpm --filter @interview-prep/extension dev",
    "extension:dev:hmr": "pnpm --filter @interview-prep/extension dev:hmr",
    "extension:build": "pnpm --filter @interview-prep/extension build",
    "extension:zip": "pnpm --filter @interview-prep/extension zip"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/seo": "^5.3.4",
    "@resvg/resvg-js": "^2.6.2",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.12",
    "mongodb": "^6.19.0",
    "nuxt": "^4.4.8",
    "satori": "^0.28.2",
    "shiki": "^4.3.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.15.30",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0"
}
