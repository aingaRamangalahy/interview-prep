# MongoDB Atlas connection string
# Local dev and production both use Atlas — no local MongoDB required.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/interview-prep?retryWrites=true&w=majority

# Single-user app identifier (progress document key)
# Retired once the Phase 2 migration to per-account user_states ships.
APP_USER_ID=default

# GitHub OAuth App credentials (github.com -> Settings -> Developer settings -> OAuth Apps)
# Authorization callback URL must be https://<domain>/api/auth/github/callback
# (register a separate dev OAuth App with http://localhost:3000/... for local dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Password for h3's sealed session cookie. Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET=

# Comma-separated GitHub logins bootstrapped as admin on first sign-in
ADMIN_GITHUB_LOGINS=

# Public app URL (production must be https://javascriptinterview.dev)
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Stable secret for signing OG image URLs across Vercel instances / rolling deploys.
# Generate with: npx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=
