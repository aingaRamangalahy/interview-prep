# MongoDB Atlas connection string
# Local dev and production both use Atlas — no local MongoDB required.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/interview-prep?retryWrites=true&w=majority

# Single-user app identifier (progress document key)
APP_USER_ID=default

# Public app URL
NUXT_PUBLIC_APP_URL=http://localhost:3000
